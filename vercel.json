{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/sheets.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/sheets",
      "destination": "/api/sheets"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
